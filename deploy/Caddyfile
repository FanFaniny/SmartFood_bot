# Caddy: статика Web App + reverse proxy до API и Telegram-вебхука.
# Домен и (опционально) e-mail для ACME берутся из переменных оточення.

{$DOMAIN} {
	encode gzip

	# SSE: без буферизации, иначе события задерживаются
	handle /api/events/stream {
		reverse_proxy api:3000 {
			flush_interval -1
		}
	}

	# API (той самий домен, шлях /api/*)
	handle /api/* {
		reverse_proxy api:3000
	}

	# Health-check API
	handle /health {
		reverse_proxy api:3000
	}

	# Telegram webhook → бот
	handle /telegram/webhook {
		reverse_proxy bot:8081
	}

	# JS/CSS с хэшем в имени (напр. /assets/index-a1b2c3.js) — безопасно кэшировать надолго.
	handle /assets/* {
		root * /srv
		header Cache-Control "public, max-age=31536000, immutable"
		file_server
	}

	# index.html и SPA-fallback — не кэшировать: после деплоя Telegram WebView
	# должен получить свежий HTML со ссылками на актуальные /assets/*.
	handle {
		root * /srv
		header Cache-Control "no-cache, no-store, must-revalidate"
		try_files {path} /index.html
		file_server
	}
}
