# ============================================================
# SmartFood Bot — Environment variables example
# Copy this file to .env and fill in the values.
# NEVER commit .env to version control.
# ============================================================

# ---- Telegram -----------------------------------------------
# Obtain from @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Bot run mode: "polling" (default, no public URL needed) or "webhook".
BOT_MODE=polling

# Secret string for webhook validation (generate a random string)
TELEGRAM_WEBHOOK_SECRET=your_webhook_secret_here

# Public HTTPS URL of the bot webhook (only for BOT_MODE=webhook),
# e.g. https://your-domain.com/telegram/webhook
TELEGRAM_WEBHOOK_URL=

# Telegram chat ID or group ID where staff notifications are sent
TELEGRAM_STAFF_CHAT_ID=-100000000000

# Staff Telegram IDs allowed to manage orders. Synced into staff_members on API start.
# Format: comma-separated "id" or "id:role" (role = cook|barista|manager|admin, default cook).
# Example: STAFF_TELEGRAM_IDS=12345678:manager,87654321:cook
STAFF_TELEGRAM_IDS=

# Internal URL the bot uses to call the API (server-to-server).
API_INTERNAL_URL=http://localhost:3000

# ---- API Server ---------------------------------------------
API_PORT=3000
API_HOST=0.0.0.0

# Public URL of the API (used for MonoPay webhook and Telegram webhook)
API_BASE_URL=https://your-domain.com

# Allowed CORS origin(s). "*" for development; set to the Web App URL in production.
CORS_ORIGIN=*

# Shared secret for staff endpoints called by the bot (header X-Internal-Secret).
# Generate a long random string. REQUIRED in production for /api/staff/*.
INTERNAL_API_SECRET=your_internal_secret_here

# Allow UNVERIFIED Telegram initData — DEVELOPMENT ONLY. Never set true in production.
ALLOW_INSECURE_TELEGRAM_AUTH=true

# ---- Database -----------------------------------------------
# Path to the SQLite database file (relative to apps/api)
DATABASE_URL=./data/smartfood.db

# Auth token for remote libsql/Turso (leave empty for local file db)
DATABASE_AUTH_TOKEN=

# Run DB migrations automatically on API startup (handy in development)
DB_AUTO_MIGRATE=true

# ---- MonoPay ------------------------------------------------
# Token from MonoPay merchant cabinet
MONOPAY_TOKEN=your_monopay_token_here

# Must be reachable from the internet (use ngrok in development)
MONOPAY_WEBHOOK_URL=https://your-domain.com/api/payments/monopay/webhook

# ---- Tenant -------------------------------------------------
# Default tenant ID — must match tenantId in packages/config/tenants/
DEFAULT_TENANT_ID=demo-cafe

# ---- App ----------------------------------------------------
NODE_ENV=development
LOG_LEVEL=info

# ---- Web App ------------------------------------------------
# Public URL of the Telegram Mini App (set in @BotFather as Menu Button URL)
VITE_API_BASE_URL=http://localhost:3000
