# ============================================================
# SmartFood — PRODUCTION env (Docker Compose)
# Скопируйте в .env на сервере:  cp .env.production.example .env
# НИКОГДА не коммитьте заполненный .env.
# ============================================================

# ---- Домен (обязательно) ------------------------------------
# Публичный домен, который указывает A-записью на IP сервера.
# Нужен для HTTPS (Telegram Mini App и webhook требуют валидный сертификат).
DOMAIN=example.com

# Web App и API на одном домене → оставьте пустым (клиент ходит на относительный /api).
# Для поддоменов: VITE_API_BASE_URL=https://api.example.com
VITE_API_BASE_URL=

# ---- Telegram (обязательно) ---------------------------------
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Секрет для проверки запросов вебхука (сгенерируйте длинную случайную строку).
TELEGRAM_WEBHOOK_SECRET=change_me_random_string
# Персонал: "id" или "id:role" (role = cook|barista|manager|admin), через запятую.
STAFF_TELEGRAM_IDS=
# (опц.) чат/группа для уведомлений персонала, если используете.
TELEGRAM_STAFF_CHAT_ID=

# ---- Безопасность API ---------------------------------------
# Общий секрет для staff-эндпоинтов (бот → API). Сгенерируйте длинную строку.
INTERNAL_API_SECRET=change_me_long_random_secret

# ---- MonoPay ------------------------------------------------
# Токен из кабинета MonoPay. Пусто → оплата-заглушка (тестовый стенд).
MONOPAY_TOKEN=
# Включить dev-страницу оплаты (ручное подтверждение) при пустом MONOPAY_TOKEN.
# true — для тестового стенда; ПОСЛЕ подключения реального MonoPay поставьте false.
ALLOW_DEV_PAYMENTS=false

# ---- Tenant / App -------------------------------------------
DEFAULT_TENANT_ID=demo-cafe
LOG_LEVEL=info

# ------------------------------------------------------------
# Примечание: API_BASE_URL, CORS_ORIGIN, MONOPAY_WEBHOOK_URL,
# ALLOW_INSECURE_TELEGRAM_AUTH, BOT_MODE, TELEGRAM_WEBHOOK_URL,
# DATABASE_URL и порты задаются автоматически в docker-compose.yml.
# ------------------------------------------------------------
