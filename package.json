{
  "name": "smartfood-bot",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=10.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:webapp": "pnpm --filter @smartfood/webapp dev",
    "dev:api": "pnpm --filter @smartfood/api dev",
    "dev:bot": "pnpm --filter @smartfood/bot dev",
    "db:migrate": "pnpm --filter @smartfood/db db:migrate",
    "db:seed": "pnpm --filter @smartfood/db db:seed",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test": "pnpm --filter @smartfood/api test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@eslint/js": "^9.28.0",
    "eslint": "^9.28.0",
    "eslint-config-prettier": "^10.1.5",
    "prettier": "^3.5.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.33.0"
  }
}
