{
  "name": "@smartfood/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch --env-file-if-exists=../../.env src/index.ts",
    "build": "tsc --build",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsc --build && vitest run",
    "test:watch": "vitest",
    "clean": "rimraf dist"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/env": "^5.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@smartfood/config": "workspace:*",
    "@smartfood/db": "workspace:*",
    "@smartfood/shared": "workspace:*",
    "@smartfood/telegram": "workspace:*",
    "drizzle-orm": "^0.44.7",
    "fastify": "^5.4.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  }
}
